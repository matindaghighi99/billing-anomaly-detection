# requirements.in — source for the locked requirements.txt.
#
# Edit THIS file, then regenerate the pinned + hash-locked lockfile with:
#   pip install pip-tools
#   pip-compile --generate-hashes --output-file=requirements.txt requirements.in
#
# requirements.txt is fully pinned with hashes so the ministry's build is
# reproducible and supply-chain-integrity-checked (pip --require-hashes).

