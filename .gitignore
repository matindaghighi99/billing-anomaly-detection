# ── Generated artefacts ──────────────────────────────────────────────────────
# All pipeline data (CSV/JSON), the SQLite databases, backups, and the runtime
# model registry are generated by the pipeline and self-healed by the app — they
# are never committed. The fee schedule (fee_schedule.csv / fee_schedule_meta.json)
# is an operator-supplied config input and IS tracked, at the repo root.
data/
reports/
data_pipeline/sql/queries.sql        # generated by create_db.py (schema.sql is tracked)

# Runtime databases + exports (also default into data/ via DATA_DIR)
*.db
audit_log_export.csv
backups/

# Model artifacts (binary, regenerated by feedback.py)
model_registry/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/

# ── Environment — NEVER commit API keys ──────────────────────────────────────
.env
.env.*
*.env
# But the example template IS committed (it contains no real values)
!.env.example

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
