# Copy this file to .env and fill in your real values.
# .env is gitignored and must NEVER be committed.

# Anthropic API key — required for AI-enriched explanations in explain.py.
# Get one at https://console.anthropic.com/settings/keys
# Set a spend limit at https://console.anthropic.com/settings/limits
ANTHROPIC_API_KEY=

# ── Production posture (see docs/PRODUCTION_READINESS.md) ─────────────────────
# Leave unset for the synthetic-data demo. In production the config gate
# (common/config.py) refuses to start unless these are set safely.
# APP_ENV=production
# SESSION_SECRET=               # ≥32 random chars, from a secrets vault
# HIDE_DEMO_CREDS=1

# ── Identity: enterprise SSO (auth/sso.py) ───────────────────────────────────
# AUTH_PROVIDER=sso             # default "mock" (password + TOTP demo)
# SSO_USER_HEADER=X-Forwarded-Email
# SSO_GROUPS_HEADER=X-Forwarded-Groups
# SSO_GROUP_ROLE_MAP={"OHIP-Audit-Admins":"admin","OHIP-Audit-Supervisors":"supervisor","OHIP-Auditors":"auditor"}
# SSO_PROXY_SHARED_SECRET=      # anti-spoofing secret the reverse proxy must send
# JWT mode (alternative to header-trust):
# SSO_JWT_HEADER=Authorization
# SSO_JWT_SECRET=               # HS256 shared secret (or use SSO_JWT_JWKS_URL for RS256)

# ── Datastore: enterprise PostgreSQL (common/db.py) ──────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname   # unset = SQLite demo
# DATA_DIR=/data                # mounted volume for SQLite/backups if not using Postgres

# ── Logging / SIEM (ops/observability.py) ────────────────────────────────────
# LOG_LEVEL=INFO                # JSON to stdout; forward the drain to your SIEM
